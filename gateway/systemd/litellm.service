# ============================================================
# FOTA 智能诊断平台 - LiteLLM Gateway systemd 服务配置
# ============================================================
# 安装步骤：
# 1. sudo cp systemd/litellm.service /etc/systemd/system/
# 2. sudo systemctl daemon-reload
# 3. sudo systemctl enable litellm
# 4. sudo systemctl start litellm

[Unit]
Description=LiteLLM Proxy - FOTA LLM API Gateway
Documentation=https://docs.litellm.ai/docs/proxy/deploy
After=network.target

[Service]
Type=exec
User=litellm
Group=litellm
WorkingDirectory=/opt/litellm-proxy

# 加载环境变量
EnvironmentFile=/opt/litellm-proxy/.env

# 启动命令（host/port 从 EnvironmentFile 读取，支持通过 $GATEWAY_LOG_PATH 重定向日志）
ExecStart=/bin/sh -c 'exec /opt/litellm-proxy/venv/bin/litellm \
    --config /opt/litellm-proxy/config.yaml \
    --host ${HOST:-127.0.0.1} \
    --port ${PORT:-4000} \
    --num_workers 4 >> ${GATEWAY_LOG_PATH:-/opt/litellm-proxy/logs/request.log} 2>&1'

# 日志输出处理
StandardOutput=inherit
StandardError=inherit

# 自动重启
Restart=always
RestartSec=5

# 安全加固
NoNewPrivileges=yes
ProtectSystem=strict
# 放宽对宿主程序目录的写权限，防止 LiteLLM 生成本地 SQLite 或者写入缓存时遭遇 Read-Only 拦截
ReadWritePaths=/opt/litellm-proxy/logs
ReadWritePaths=/opt/litellm-proxy
PrivateTmp=yes

# 资源限制
LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
