# ============================================================
# FOTA 智能诊断平台 - LiteLLM Gateway 环境配置
# ============================================================
# 使用方法：cp .env.example .env && vim .env
# ⚠️ .env 包含 API Keys，严禁提交到 Git 仓库
#
# 本文件中的每个变量都对应 config.yaml 中 os.environ/ 引用
# 或 LiteLLM 启动脚本 (scripts/start.sh) 中的读取
# ============================================================

# ────────────────────────────────────────────────────────────
# 1. Anthropic API Keys
# ────────────────────────────────────────────────────────────
# config.yaml 中各模型的 API Key 对应关系：
#   router-model (Haiku)         → ANTHROPIC_API_KEY
#   agent-model Key#1 (Sonnet)   → ANTHROPIC_API_KEY_1
#   agent-model Key#2 (Sonnet)   → ANTHROPIC_API_KEY_2
#   synthesizer-model (Sonnet)   → ANTHROPIC_API_KEY_1
# 多 Key 实现 Key Pool 轮转，防御 429 限流（详见 config.yaml agent-model 段）
# 申请地址：https://console.anthropic.com/

# [必填] Anthropic 主 Key — 用于 router-model (Haiku)
ANTHROPIC_API_KEY=sk-ant-api00-xxxxxxxxxxxxx

# [必填] Anthropic Agent/Synthesizer Key#1 — 用于 agent-model 和 synthesizer-model
ANTHROPIC_API_KEY_1=sk-ant-api01-xxxxxxxxxxxxx

# [必填] Anthropic Agent Key#2 — 用于 agent-model 轮转池（双 Key 防御 429）
ANTHROPIC_API_KEY_2=sk-ant-api02-xxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 2. OpenAI API Keys
# ────────────────────────────────────────────────────────────
# config.yaml 中所有 OpenAI Fallback deployment 共用此 Key
# 申请地址：https://platform.openai.com/api-keys

# [必填] OpenAI Key — 用于 router/agent/synthesizer/embedding 的 Fallback
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 3. 上游 API Base URL（中转地址）
# ────────────────────────────────────────────────────────────
# 对应 config.yaml 中每个 deployment 的 litellm_params.api_base
# - 国内部署：填入 NewAPI / OneAPI 等中转服务地址
# - 海外部署：留空，LiteLLM 自动使用官方默认地址
#
# ⚠️ LiteLLM 的 os.environ/ 语法在变量为空时会回退到供应商默认 URL
#    所以海外部署直接留空即可，无需删除

# [条件必填] Anthropic 上游地址（官方默认：https://api.anthropic.com）
# 国内中转示例：https://your-newapi.com 或 https://your-oneapi.com/anthropic
ANTHROPIC_API_BASE=

# [条件必填] OpenAI 上游地址（官方默认：https://api.openai.com/v1）
# 国内中转示例：https://your-newapi.com/v1 或 https://your-oneapi.com/v1
OPENAI_API_BASE=

# ────────────────────────────────────────────────────────────
# 4. LiteLLM 管理密钥
# ────────────────────────────────────────────────────────────
# 对应 config.yaml → general_settings.master_key
# 用于 LiteLLM Admin UI 和管理 API（/key/generate 等）
# 请生成强随机字符串：openssl rand -hex 32

# [必填] LiteLLM 管理员密钥
LITELLM_MASTER_KEY=sk-litellm-master-xxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 5. 服务监听配置
# ────────────────────────────────────────────────────────────
# scripts/start.sh 和 systemd service 读取这两个变量
# Backend 的 LITELLM_BASE_URL 应指向 http://{HOST}:{PORT}/v1

# [可选] 监听地址（默认 127.0.0.1，仅本机访问；改为 0.0.0.0 允许外部访问）
HOST=127.0.0.1

# [可选] 监听端口（默认 4000）
PORT=4000

# ────────────────────────────────────────────────────────────
# 6. 可选：数据库（Virtual Key 管理）
# ────────────────────────────────────────────────────────────
# 基础功能（Fallback、Key Pool、重试）不依赖数据库
# 仅在需要 Virtual Key 管理和用量持久化时启用
# DATABASE_URL=postgresql://user:password@localhost:5432/litellm

# ────────────────────────────────────────────────────────────
# 7. 可选：Redis（分布式限流）
# ────────────────────────────────────────────────────────────
# 单机部署不需要；多实例部署时用于共享限流计数器
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────
# 8. 可选：日志路径
# ────────────────────────────────────────────────────────────
# systemd service 的 ExecStart 使用此路径重定向 LiteLLM 请求日志
# 未设置时默认写入 /opt/litellm-proxy/logs/request.log
# GATEWAY_LOG_PATH=/opt/litellm-proxy/logs/request.log
