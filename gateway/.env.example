# ============================================================
# FOTA 智能诊断平台 - LiteLLM Gateway 环境配置示例
# ============================================================
# 复制此文件为 .env 并填入真实配置
# ⚠️ 警告：此文件包含 LLM API Keys，严格保密，不要提交到版本库

# ── LLM 供应商 API Keys ──
# 从 Anthropic 官网申请：https://console.anthropic.com/
# 支持配置多个 Key 实现 Key Pool 轮转（详见 config.yaml）
ANTHROPIC_API_KEY=sk-ant-api00-xxxxxxxxxxxxx
ANTHROPIC_API_KEY_1=sk-ant-api01-xxxxxxxxxxxxx
ANTHROPIC_API_KEY_2=sk-ant-api02-xxxxxxxxxxxxx

# 从 OpenAI 官网申请：https://platform.openai.com/api-keys
# 建议使用同一 Organization 下的多个 Project Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_API_KEY_PROJECT_A=sk-proj-xxxxxxxxxxxxx
OPENAI_API_KEY_PROJECT_B=sk-proj-xxxxxxxxxxxxx

# ── LiteLLM 管理密钥 ──
# 用于调用 LiteLLM 管理接口和 Admin UI
# 请生成一个强随机字符串（建议 32 字符以上）
LITELLM_MASTER_KEY=sk-litellm-master-xxxxxxxxxxxxx

# ── 上游 API 代理地址（可选） ──
# 场景 A（平台在国内）：必须配置中转 URL（如：https://api.openai-proxy.com/v1）
# 场景 B（平台在海外）：可保持为空或删除，系统将自动回退到官方 API 地址
UPSTREAM_API_BASE=


# ── 服务配置 ──
# LiteLLM Proxy 监听地址和端口
HOST=127.0.0.1
PORT=4000

# ── 数据库配置（可选）──
# 如需 Virtual Key 管理和用量持久化，配置 PostgreSQL
# 基础功能（Fallback、Key Pool、重试）不依赖数据库
# DATABASE_URL=postgresql://user:password@localhost:5432/litellm

# ── Redis 配置（可选）──
# 用于分布式限流和缓存
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=