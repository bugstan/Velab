# ============================================================
# FOTA 智能诊断平台 - Backend 环境配置示例
# ============================================================
# 复制此文件为 .env 并填入真实配置
# 注意：.env 文件包含敏感信息，不要提交到版本库

# ── 基础配置 ──
PROJECT_NAME="FOTA 智能诊断平台"

# ── 部署模式 ──
# A = 场景 A（平台在国内，通过 LiteLLM 网关中转访问海外 LLM API）
# B = 场景 B（平台在海外，直连 Claude/OpenAI API）
DEPLOYMENT_MODE=A

# ── LLM API 配置（场景 A：LiteLLM 中转）──
# 仅在 DEPLOYMENT_MODE=A 时使用
# LITELLM_BASE_URL 指向您部署的 LiteLLM Proxy 地址
LITELLM_BASE_URL=https://llm-proxy.example.com/v1
LITELLM_API_KEY=sk-fota-virtual-key

# ── LLM API 配置（场景 B：直连供应商）──
# 仅在 DEPLOYMENT_MODE=B 时使用
# 从 Anthropic 和 OpenAI 官网申请
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 供应商自定义端点（可选，默认为官方地址）
# 如在海外使用代理或私有化部署，可在此修改
# ANTHROPIC_API_BASE=https://api.anthropic.com
# OPENAI_API_BASE=https://api.openai.com/v1

# ── 数据库配置 ──
# PostgreSQL 用于存储案件元数据、标准事件表、向量索引
POSTGRES_USER=postgres
POSTGRES_PASSWORD=fota_password
POSTGRES_DB=fota_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis 配置 ──
# 用于任务队列、缓存、会话管理
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MinIO / S3 对象存储配置 ──
# 用于存储原始日志文件、文档、报告
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fota-logs
MINIO_SECURE=false

# ── 编排器配置 ──
# 是否启用流式响应（SSE）
ORCHESTRATOR_STREAM=true

# ── 日志配置 ──
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── 性能配置 ──
# 快速通道时间窗口缓冲（分钟）
FAST_PARSE_TIME_BUFFER_MINUTES=15

# 并发 Parser Worker 数量
PARSER_MAX_WORKERS=4

# LLM 请求超时（秒）
LLM_REQUEST_TIMEOUT=120

# ── 语义缓存配置 ──
# 语义相似度阈值（0.0-1.0）
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95

# 缓存 TTL（秒）
SEMANTIC_CACHE_TTL_ROUTER=86400
SEMANTIC_CACHE_TTL_AGENT=14400
SEMANTIC_CACHE_TTL_SYNTHESIZER=7200
