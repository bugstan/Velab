MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5

# 使用 MiniMax-M2.5-highspeed 等高速变体（编排 + 最终流式均生效，已为 true）
MINIMAX_USE_HIGHSPEED=true

# 编排器用流式 chat/completions（更快收到首包；需等流结束才有完整 tool_calls）
MINIMAX_ORCHESTRATOR_STREAM=false

# 调用链 DEBUG 日志（见 common/chain_log.py）；也可 export LOG_LEVEL=INFO 减少输出
LOG_LEVEL=DEBUG
