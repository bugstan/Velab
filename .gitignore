scripts/deploy-old.sh.bak
scripts/*.bak

# 测试数据
test-data/
test-logs/

# 临时分析结果
analysis-output/
reports/

# AI 助手生成的项目文档（自动生成，不纳入版本控制）
# claude.md - 项目完整文档，纳入版本控制
cursor.md
*.ai.md

# ── 保留的文件（明确不忽略）──
# 确保这些重要文件被提交
!.env.example
!backend/.env.example
!gateway/.env.example
!README.md
!*/README.md
!docs/**/*.md
!*.example
