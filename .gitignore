*.pid
*.sock

# ── 备份文件 ──
*.bak
*.backup
*.old
*~

# ── 敏感数据 ──
# API Keys、密钥、证书等
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# ── 大文件 ──
# 原始日志包、数据集等
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.dlt
# 但保留文档中的示例压缩包
!docs/**/*.zip
!docs/**/*.tar.gz

# ── 特定目录 ──
# 对象存储本地缓存
minio-data/
s3-cache/

# PostgreSQL 数据目录
postgres-data/

# Redis 数据目录
redis-data/

# 日志归档
Log/
log/

# ── 项目特定 ──
